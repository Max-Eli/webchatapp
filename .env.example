# Anthropic (server-side, for translation)
ANTHROPIC_API_KEY=sk-ant-...

# LiveKit Cloud (handles all WebRTC infrastructure: signaling, TURN, ICE)
# Sign up free at https://livekit.io/cloud
# After creating a project, copy these from the project's Settings > Keys page.
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secret-xxxxxxxxxx
NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
